generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  phone         String?   @unique
  phoneVerified DateTime?
  vehiclePlate  String?
  companyName   String?
  image         String?
  role          String    @default("USER")
  isSuspended   Boolean   @default(false)
  isAvailable   Boolean   @default(false)
  lat           Float?
  lng           Float?
  preferredCity String?   @default("İstanbul")
  serviceCity          String?
  serviceDistricts     String?
  serviceNeighborhoods String?

  accounts      Account[]
  sessions      Session[]

  postedJobs       Job[]     @relation("CustomerJobs")
  acceptedJobs     Job[]     @relation("OperatorJobs")
  reviewsGiven     Review[]  @relation("CustomerReviews")
  reviewsReceived  Review[]  @relation("OperatorReviews")

  businessImages BusinessImage[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? 
  access_token       String? 
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? 
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BusinessImage {
  id        String   @id @default(cuid())
  url       String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())
  rating      Int      @default(5)
  comment     String?
  
  customerId  String
  customer    User     @relation("CustomerReviews", fields: [customerId], references: [id])
  
  operatorId  String
  operator    User     @relation("OperatorReviews", fields: [operatorId], references: [id])
  
  jobId       String?  @unique
  job         Job?     @relation(fields: [jobId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Job {
  id          String    @id @default(cuid())
  serviceType  String    @default("Foseptik Çukuru Boşaltma")
  description  String?
  status       String    @default("PENDING")
  
  lat          Float
  lng          Float
  city         String    @default("Belirtilmemiş")
  district     String    @default("Belirtilmemiş")
  neighborhood String    @default("Belirtilmemiş")

  isEmergency  Boolean   @default(false)

  customerId  String
  customer    User      @relation("CustomerJobs", fields: [customerId], references: [id])
  
  operatorId  String?
  operator    User?     @relation("OperatorJobs", fields: [operatorId], references: [id])

  review      Review?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}


model Province {
  id        String     @id
  name      String
  districts District[]
}

model District {
  id            String         @id
  name          String
  provinceId    String
  province      Province       @relation(fields: [provinceId], references: [id])
  neighborhoods Neighborhood[]
}

model Neighborhood {
  id         String   @id
  name       String
  districtId String
  district   District @relation(fields: [districtId], references: [id])
}

model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
